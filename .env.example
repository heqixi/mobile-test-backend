# --- AI Model Configuration ---
MIDSCENE_MODEL_BASE_URL=""
MIDSCENE_MODEL_API_KEY=""
MIDSCENE_MODEL_NAME=""
MIDSCENE_MODEL_FAMILY=""

# --- Agent Service (:4100) + OpenCode Server (:4096) ---
# AGENT_PORT=4100
# OPENCODE_URL=http://127.0.0.1:4096
# OPENCODE_DIRECTORY=
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=
# OPENCODE_PROVIDER_ID=unsloth_studio
# OPENCODE_MODEL_ID=Qwen3.5-9B
# 须在 ~/.config/opencode/opencode.jsonc 为该模型声明：
#   attachment: true
#   modalities: { input: ["text","image"], output: ["text"] }
# （与 Midscene / llama-server :8888 + mmproj 同源）

# --- Android (optional, only for Android tests) ---
# ANDROID_APP_PACKAGE="cn.wps.moffice_eng"
# MIDSCENE_ADB_PATH=""            # Custom adb binary path
# MIDSCENE_ADB_REMOTE_HOST=""     # Remote ADB host (for wireless debugging)
# MIDSCENE_ADB_REMOTE_PORT=""     # Remote ADB port

# --- iOS (optional, only for iOS tests) ---
# WDA port defaults to 8100. Override via IOSTest.init({ deviceOptions: { wdaPort: ... } })
