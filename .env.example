# Copy to .env and fill in. Secrets stay local — never commit .env.
# After pull on a new machine: configure Midscene + OpenCode below, then run.

# --- Midscene (Executor / aiAct / aiLocate) — OpenAI-compatible endpoint ---
# Examples:
#   OpenAI:   BASE_URL=https://api.openai.com/v1  FAMILY=gpt / follow Midscene docs
#   Gemini:   via OpenAI-compatible proxy or Midscene-supported Gemini family
#   Local VL: BASE_URL=http://127.0.0.1:8888/v1
MIDSCENE_MODEL_BASE_URL=""
MIDSCENE_MODEL_API_KEY=""
MIDSCENE_MODEL_NAME=""
MIDSCENE_MODEL_FAMILY=""

# --- OpenCode (Agent plan/judge + Case LLM compile) ---
# HTTP only — no sibling opencode/ source tree. Start with: npm run opencode:serve
# (requires CLI: brew install opencode  OR  npm i -g opencode-ai)
# Must match a provider/model declared in ~/.config/opencode/opencode.jsonc
# (or your OPENCODE_DIRECTORY). No local studio defaults in code — set these.
OPENCODE_URL=http://127.0.0.1:4096
OPENCODE_PROVIDER_ID=
OPENCODE_MODEL_ID=
# OPENCODE_BIN=                 # optional path to opencode binary
# OPENCODE_PORT=4096
# OPENCODE_HOSTNAME=127.0.0.1
# OPENCODE_DIRECTORY=
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=
# Multimodal (screenshots): provider model should allow image input, e.g.
#   attachment: true
#   modalities: { input: ["text","image"], output: ["text"] }

# --- Local service ports / URLs (override when not using defaults) ---
# AGENT_PORT=4100
# AGENT_HOST=127.0.0.1
# AGENT_URL=http://127.0.0.1:4100
# EXECUTOR_PORT=4098
# EXECUTOR_URL=http://127.0.0.1:4098
# CASE_PORT=4102
# CASE_LIBRARY_URL=http://127.0.0.1:4103
# COWORK_LIBRARY_PORT=4103
# GOAL_SPACE_URL=http://127.0.0.1:4104
# GOAL_SPACE_PORT=4104
# GOAL_SPACE_ID=cowork-android
# GOAL_SPACE_VERSION=                 # 可选；缺省 latest（例：2026-07-23T02-36-43）
# AGENT_GOAL_SPACE=1                  # 0 关闭；Agent 按需 retrieve（FE 绑定优先）
# COWORK_GOAL_SPACE=1                 # 0 关闭编译期可选 enrich（非 Agent 主路径）
# 注意：FE 绑定 URL+spaceIds = Agent 检索 scope；禁止整图硬塞上下文
# COWORK_CSV_PATH=                       # override default CSV path
# COWORK_CSV_DATA_DIR=                   # override business/cowork-csv/data

# --- Agent Loop knobs ---
# AGENT_MAX_JUDGE_FAILURES=3
# AGENT_ACT_TIMEOUT_MS=45000              # Midscene act / Playground（点击等）超时
# AGENT_ACT_INPUT_TIMEOUT_MS=120000       # Input / 多行输入等更长超时
# AGENT_POST_ACT_SCREENSHOT_DELAY_MS=1000 # act 结果回调后、下一轮截图前等待
# AGENT_PLAYGROUND_CLAIM_TIMEOUT_MS=8000  # 前端未 ack 时回退 freeform 的等待
# MIDSCENE_AI_ACT_TIMEOUT_MS=120000       # executor freeform aiAct AbortSignal 超时
# AGENT_VISUAL_EVIDENCE=final  # off | final | failed | always
# AGENT_VISUAL_EVIDENCE_MAX_TARGETS=3
# AGENT_VISUAL_EVIDENCE_DEEP_LOCATE=1
# AGENT_VISUAL_EVIDENCE_PROMPT=1

# --- Goal Space screen identity (act 后生长终审，无 embedding) ---
# auto（默认）: 配置了 MIDSCENE_MODEL_* 则走 VL JSON 终审，否则启发式
# openai | heuristic | off
# GOAL_SPACE_SCREEN_IDENTITY=auto
# auto | openai | heuristic — spawn 时屏名/词条标注（默认跟 Midscene VL）
# GOAL_SPACE_KEYFRAME_LABEL=auto

# --- Android (optional) ---
# ANDROID_APP_PACKAGE="cn.wps.moffice_eng"
# MIDSCENE_ADB_PATH=""
# MIDSCENE_ADB_REMOTE_HOST=""
# MIDSCENE_ADB_REMOTE_PORT=""
# MIDSCENE_REPLANNING_CYCLE_LIMIT=5
# MIDSCENE_AI_ACT_MAX_ACTIONS=1   # 全局默认；不设则不限制。Agent 对点击类会按次传 maxActions=1

# --- iOS (optional) ---
# WDA port defaults to 8100. Override via IOSTest.init({ deviceOptions: { wdaPort: ... } })

# --- Cowork CSV library defaults ---
# Default CSV: business/cowork-csv/data/cowork_test_case_p0.csv
# Reports:     <csv>.reports/
